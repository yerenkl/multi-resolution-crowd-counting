    for noise in "${NOISE_OPTIONS[@]}"; do

        # Skip invalid combos (bilinear doesn't need both)
        if [[ "$method" != "mix" && "$noise" == "false" ]]; then
            continue
        fi

        echo "========================================"
        echo "Running pipeline for method: $method | noise: $noise"
        echo "========================================"

        # Build path dynamically
