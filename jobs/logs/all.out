# LSBATCH: User input
#!/bin/bash
#BSUB -q gpua100
#BSUB -W 24:00
#BSUB -J finetune_res_aug
#BSUB -o jobs/logs/finetune_res_aug_%J.out
#BSUB -e jobs/logs/finetune_res_aug_%J.err
#BSUB -n 4
#BSUB -R "rusage[mem=32GB]"
#BSUB -R "span[hosts=1]"
#BSUB -gpu "num=1:mode=exclusive_process"

set -euo pipefail


uv sync


METHODS=("bicubic" "bilinear" "nearest" "lanczos")

DEVICE="cuda:0"

for method in "${METHODS[@]}"; do
    echo "========================================"
    echo "Running pipeline for method: $method"
    echo "========================================"

    if [ "$method" != "bicubic" ]; then
        uv run python entrypoints/downscale_nwpu.py \
            --method "$method"
    else
        echo "Skipping downscale_nwpu.py for method: bicubic"
    fi


    uv run python entrypoints/train_finetune_res_aug.py \
        --device "$DEVICE" \
        --epochs 50 \
        --batch_size 8 \
        --lr 1e-5 \
        --num_workers 4 \
        --method "$method"

    uv run python entrypoints/eval_zoom_pairs.py \
        --device "$DEVICE" \
        --method "$method"

    uv run python entrypoints/eval_nwpu_native.py \
        --device "$DEVICE" \
        --method "$method"


