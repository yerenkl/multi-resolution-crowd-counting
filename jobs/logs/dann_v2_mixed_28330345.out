    --device cuda:0 \
    --epochs 50 \
    --batch_size 8 \
    --lr 1e-5 \
    --lr_disc 1e-4 \
    --dann_weight 1.0 \
    --lr_scales 2 4 \
    --hidden_dim 256 \
    --dropout 0.5 \
    --num_workers 4 \
    --eval_limit 500

echo "Done."

